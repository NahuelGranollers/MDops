NODE_ENV=development
APP_NAME=MD Ops
PUBLIC_APP_URL=https://agenda.tudominio.com
WEB_PORT=3000
API_PORT=4000

POSTGRES_DB=md_ops
POSTGRES_USER=md_ops
POSTGRES_PASSWORD=cambia_esta_password_larga
POSTGRES_IMAGE=public.ecr.aws/docker/library/postgres:16-alpine
POSTGRES_PORT=55432
DATABASE_URL=postgresql://md_ops:cambia_esta_password_larga@localhost:55432/md_ops?schema=public

JWT_ACCESS_SECRET=cambia_este_secreto_access_de_32_chars_minimo
JWT_REFRESH_SECRET=cambia_este_secreto_refresh_de_32_chars_minimo
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
AUTOLOGIN_ENABLED=true
AUTOLOGIN_IDENTIFIER=admin
AUTOLOGIN_ALLOW_PRODUCTION=false
COOKIE_DOMAIN=
CORS_ORIGIN=https://agenda.tudominio.com

DEFAULT_TIMEZONE=Europe/Madrid
MIN_REST_HOURS=10
REST_CONFLICT_MODE=warn

UPLOAD_DIR=/data/uploads
SESSION_LOG_DIR=./logs
SESSION_LOG_SLOW_MS=1500
MAX_UPLOAD_MB=25

MAPS_PROVIDER=mock
GOOGLE_MAPS_API_KEY=

EMAIL_NOTIFICATIONS_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=MD Ops
SMTP_REPLY_TO=
