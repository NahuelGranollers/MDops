{
  "version": 2,
  "buildCommand": "pnpm --filter @md-ops/api build && STATIC_EXPORT=true pnpm --filter @md-ops/web build",
  "outputDirectory": "apps/web/out",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/serverless"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/api/serverless"
    }
  ]
}
