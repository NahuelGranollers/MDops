{
  "version": 2,
  "builds": [
    {
      "src": "api.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "ignore": [
    "apps/**",
    "packages/**",
    "docs/**",
    "scripts/**",
    "infra/**",
    ".github/**"
  ]
}
