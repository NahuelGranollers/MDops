{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/serverless"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/api/serverless"
    }
  ]
}
