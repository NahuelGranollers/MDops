{
  "version": 2,
  "builds": [
    {
      "src": "api.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "api.ts"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "HEAD", "OPTIONS"]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
